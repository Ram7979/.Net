@{
}
@model StudentManagementSystem.Models.Student

<h2>Student Profile</h2>

<p><b>Name:</b> @Model.StudentName</p>
<p><b>Email:</b> @Model.Email</p>
<p><b>Phone:</b> @Model.PhoneNumber</p>
<p><b>Address:</b> @Model.Address</p>

<p><b>Department:</b> @Model.Department.DepartmentName</p>
<p><b>Course:</b> @Model.Course.CourseName</p>